        "12)A music player supports:\n",
        "• Next Song\n",
        "• Previous Song\n",
        "• Continuous looping\n",
        "Tasks:\n",
        "• Explain why Doubly Circular Linked List is the best choice.\n",
        "• Draw the structure.\n",
        "• Implement next and previous navigation in Python."
      ]
    },
    {
      "cell_type": "raw",
      "id": "cb10fca4-f325-4a5f-bcfe-c96a38213d86",
      "metadata": {},
      "source": [
        "class SongNode:\n",
        "    def __init__(self, title):\n",
        "        self.title = title\n",
        "        self.prev = None\n",
        "        self.next = None\n",
        "\n",
        "\n",
        "class MusicPlayer:\n",
        "    def __init__(self):\n",
        "        self.head = None\n",
        "        self.current = None\n",
        "\n",
        "    # Add song at end of circular doubly linked list\n",
        "    def add_song(self, title):\n",
        "        new_node = SongNode(title)\n",
        "\n",
        "        if self.head is None:\n",
        "            self.head = new_node\n",
        "            new_node.next = new_node\n",
        "            new_node.prev = new_node\n",
        "            self.current = new_node\n",
        "        else:\n",
        "            last = self.head.prev\n",
        "\n",
        "            last.next = new_node\n",
        "            new_node.prev = last\n",
        "\n",
        "            new_node.next = self.head\n",
        "            self.head.prev = new_node\n",
        "\n",
        "    def play_current(self):\n",
        "        if self.current:\n",
        "            print(f\"Now Playing: {self.current.title}\")\n",
        "        else:\n",
        "            print(\"Playlist is empty.\")\n",
        "\n",
        "    # Next song\n",
        "    def next_song(self):\n",
        "        if self.current:\n",
        "            self.current = self.current.next\n",
        "            self.play_current()\n",
        "\n",
        "    # Previous song\n",
        "    def prev_song(self):\n",
        "        if self.current:\n",
        "            self.current = self.current.prev\n",
        "            self.play_current()\n",
        "\n"
      ]
    },
